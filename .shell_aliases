# Productivity
alias ls='ls -hvF --show-control-chars --color=always'                                                         
alias l='ls -CF --group-directories-first'                  

alias ll='ls -l'                                                                                                   
alias la='ll -A'                                                                                                   
alias lm='ll | more'       										                                                   
alias lr='ll -R | more'    										                                                   
alias lx='ls -lXB'         										                                                   
alias lk='ls -lSr'         										                                                   
alias lt='ls -ltr'         										                                                   
alias lc='ls -ltcr'        										                                                   
alias lu='ls -ltur'        										                                                   

alias J='jobs -l'

alias c='clear'
alias y='yes'
alias d='echo */'

alias 'ps?'='ps aux | grep -v "grep" | grep -i'                                                         # find PID by name
alias pa='ps aux'
alias px='ps x'
alias pt='ps -hH -p'

alias k='kill -s KILL'
alias ka='killall -s KILL'

alias debug='set -o nounset; set -o xtrace'

alias rm='rm -R -I'
alias cp='cp -R -i'
alias mv='mv -i'
alias ca="cat -A"

alias df='df -kh'
alias du='du -kh --max-depth=1'

alias vi='vim'
alias scp='scp -prC'

alias vn='vim -u NONE'
alias vd='vim -d'
alias svi='sudo vim'

alias rs='rsync -acyhuvizP --delete-excluded --delete --delete-after --force --stats'
alias hs='history'

alias mkdir='mkdir -pv'										                                            # prevents accidentally clobbering files
alias less='less -RN'                                                                                        # raw control characters

alias g='grep -ia --color=auto'                                  
alias eg='egrep -ia --color=auto'                                

alias ag='ag -U --silent --workers $MAX_JOBS --depth=10000 --ignore={.git,.svn,.hg,.repo,.vscode} --stats'
alias rg='rg -Sp -j $MAX_JOBS --color always -g "!{.git,.svn,.hg,.repo,.vscode}" --stats'
alias tailf='tail -F -n 200'                                    

alias hstg='history | grep'                                                                                 # search history quickly

alias t="\tree -A -I '.svn' -I '.git' -I '.repo' -I '.vscode'" 
alias mt="\tree -atqhfDQCF --dirsfirst --timefmt='%Y-%m-%d %H:%M:%S' -I '.svn' -I '.git' -I '.repo' -I '.vscode' | \less -RgIJKNW" 

# Network
alias wsget='wget --random-wait -r -p -e robots=off -U mozilla'                                             # download entire website
alias ipinfo='curl ipinfo.io/json'                                                                          # show public ip address
    
alias logo=neofetch

# Special alias by OS type
case ${OSTYPE} in
  'cygwin'*)
    alias tcpdump='windump'
    alias open='cygstart'
    alias e.='explorer.exe .'
    alias battery-status='powercfg /batteryreport'
    
    alias k='kill -f -s KILL'
    alias ka='killall -I -s KILL'

    alias pa='ps aux -W'
    alias px='ps x -W'
    alias pt='ps -hH -p -W'
    alias 'ps?'='ps aux -W | grep -v "grep" | grep -i'                                                      # find PID by name

    ;;

  'msys'*)
    alias pacman-update='pacman -Syyu --noconfirm --overwrite \*'
    
    ;;

  'freebsd'*)
    alias ls='ls -hFBG'                                                                                            
    alias l='ls -CF'                                            
    
    ;;

  'darwin'*)
    unalias ls
    alias ls='ls -hFBG'                                                                                            
    
    unalias l
    alias l='ls -CF'                                            
    
    unalias du
    alias du='du -kh -d=1'

    unalias rm
    alias rm='rm -R'
    
    ;;

  *)
    alias apt-update='sudo apt clean;sudo apt update -y;sudo apt upgrade -y;sudo apt-get autoremove -y'
    alias dnf-update='sudo dnf update -y'
    alias pacman-update='sudo pacman -Syyu --noconfirm --overwrite \*'
    
    alias restart='sudo reboot'
    alias halt='sudo shutdown -h now'
    
    alias mount='mount | column -t'
    alias free='free -mlth -s 2'                                                                               
    alias sysinfo='inxi -Fx'                                                                                
    alias ping='ping -c 4'

    ;;
esac

