" **  pylint
if executable('pylint')
    function! EnaPylint()
        set makeprg=pylint\ --reports=n\ --msg-template=\"{path}:{line}:\ {msg_id}\ {symbol},\ {obj}\ {msg}\"\ %:p
        set errorformat=%f:%l:\ %m
    endfunction
endif

autocmd FileType python silent call EnaPylint()
